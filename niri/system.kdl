workspace "system"
		
		window-rule {
				match app-id="kitty" title="peaclock"
				open-floating true
				default-column-width { proportion 0.25; }
				default-window-height { proportion 0.17; }
				default-floating-position x=120 y=20 relative-to="top-left"					
		}
		window-rule {
				match app-id="librewolf" 
				match app-id="qutebrowser"
				open-floating false
				open-on-workspace "system"
				default-column-width { proportion 0.5; }
				opacity 1.0
		}


